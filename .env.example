# --- Localhost (DEV_MODE=true) ---
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=predictliga_bot
WEBAPP_URL=http://localhost:5173
SERVER_URL=http://127.0.0.1:3001
PORT=3001
NODE_ENV=development
DEV_MODE=true
DISABLE_CRON=true

# Telegram user IDs администраторов (через запятую). Узнать ID: @userinfobot
# Для localhost без Telegram: 999999 — ID тестового пользователя (createDevUser)
ADMIN_USER_IDS=999999

# Production: NODE_ENV=production, DEV_MODE=false, реальный BOT_TOKEN и WEBAPP_URL
# Короткое имя Mini App из BotFather → t.me/predictliga_bot/predictliga?startapp=...
WEBAPP_SHORT_NAME=predictliga

# API-Sports (api-football) — автоподтягивание счёта и fantasy-событий
# FOOTBALL_API_KEY=your_api_sports_key
# FOOTBALL_API_LEAGUE_ID=1
# FOOTBALL_API_SEASON=2026
# FOOTBALL_SYNC_ENABLED=true

# Кэш глобального рейтинга (мс), по умолчанию 60000
# LEADERBOARD_CACHE_TTL_MS=60000